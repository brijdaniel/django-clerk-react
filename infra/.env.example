# Copy to .env.dev and .env.prod, then fill in real values.
# manage.sh reads ALL params from this file and passes them to Bicep
# (init/preview only — code deploys are CI-driven, see .github/workflows/).
# One file per environment — no other config files needed.

# --- manage.sh config (not Bicep params) ---
RESOURCE_GROUP=

# --- Infrastructure ---
ENVIRONMENT_NAME=dev
# Base name for all Azure resources ('<APP_NAME>-api-<env>', etc.).
# Must match APP_BASE_NAME in .github/workflows/deploy-prod.yml.
APP_NAME=app
ACR_NAME=myregistrycr
CREATE_ACR=true
ACR_LOGIN_SERVER=

# --- VNet (prod only — set USE_VNET=false for dev) ---
USE_VNET=false
VNET_NAME=
VNET_CIDR=
ACA_SUBNET_CIDR=
PE_SUBNET_CIDR=
API_MIN_REPLICAS=0
API_MAX_REPLICAS=1
WORKER_MIN_REPLICAS=0
WORKER_MAX_REPLICAS=1
API_CPU=0.25
API_MEMORY=0.5Gi
WORKER_CPU=0.25
WORKER_MEMORY=0.5Gi
BEAT_CPU=0.25
BEAT_MEMORY=0.5Gi

# --- Django ---
DEBUG=1
TEST=True

# --- Secrets ---
DJANGO_SECRET_KEY=
POSTGRES_PASSWORD=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
CELERY_BROKER_URL=
AZURE_STORAGE_ACCOUNT_KEY=

# --- Database ---
POSTGRES_HOST=
POSTGRES_DB=
POSTGRES_USER=

# --- Clerk ---
CLERK_FRONTEND_API=
CLERK_AUTHORIZED_PARTIES=

# --- Networking ---
ALLOWED_HOSTS=*
CORS_ALLOWED_ORIGINS=

# --- Storage ---
STORAGE_PROVIDER_CLASS=app.utils.storage.AzureBlobStorageProvider
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_CONTAINER=media

# --- URLs ---
# Public frontend URL, including scheme (e.g. https://app.example.com)
FRONTEND_URL=

# --- Monitoring ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# --- Billing ---
FREE_CREDIT_AMOUNT=10.00
USAGE_RATE_DEFAULT=0.10
